<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_primary"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp">

        <!-- Glow ring behind logo -->
        <View
            android:id="@+id/viewGlow"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/bg_glow_ring"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- App Logo -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- App name under logo -->
        <TextView
            android:id="@+id/tvAppLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Shield"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/ivLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Setup Required"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:textAlignment="center"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/tvAppLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant the permissions below to enable real-time threat detection"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Why we need permissions card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardExplanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_card_cyber">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WHY WE NEED ACCESS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="14dp" />

                <!-- Permission row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="🔔"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Monitor incoming notifications in real-time"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Permission row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="🛡️"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Analyze content for spam, phishing and scams"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Permission row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="⚡"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Show instant heads-up alerts for threats"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Permission row 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="📋"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Keep a local history of analyzed notifications"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Privacy note -->
        <TextView
            android:id="@+id/tvPrivacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒  100% offline — your data never leaves your device"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:textAlignment="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardExplanation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Grant Notification Access Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantPermission"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Grant Notification Access"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/bg_primary"
            android:backgroundTint="@color/accent_blue"
            app:cornerRadius="12dp"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/tvPrivacy"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Grant Overlay Permission Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantOverlay"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Allow Display Over Other Apps"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/bg_primary"
            android:backgroundTint="@color/accent_cyan"
            app:cornerRadius="12dp"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/btnGrantPermission"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Skip Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Skip for now"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnGrantOverlay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Warning Message -->
        <TextView
            android:id="@+id/tvWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️  App cannot function without notification access. Please grant the permission."
            android:textSize="13sp"
            android:textColor="@color/high_risk_red"
            android:textAlignment="center"
            android:padding="14dp"
            android:background="@drawable/bg_card_cyber"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnSkip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
